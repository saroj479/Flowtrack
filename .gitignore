# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environment (created by install.sh inside ~/.focusaudit/venv)
venv/
.venv/
env/

# User data — never commit personal logs or screenshots
*.jsonl
*.jpg
*.jpeg
*.png
reports/
logs/
screenshots/

# systemd service generated at install time (contains hard-coded $HOME paths)
# The template is focusaudit.service — that one IS tracked
*.service.local

# Editor / OS artefacts
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db
